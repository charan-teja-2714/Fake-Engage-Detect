# ── Claude Code ───────────────────────────────────────────────────────────────
/.claude
.claude

# ── Mobile App ───────────────────────────────────────────────────────────────
# Keep source code, ignore build outputs and dependencies

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────────────────────────────
venv/
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log

# ── Raw dataset (2.2 GB — never commit) ──────────────────────────────────────
dataset/raw/

# ── Processed dataset: keep features_dataset.csv (needed by predict.py)
#    but ignore the large final_dataset.csv ────────────────────────────────────
dataset/processed/final_dataset.csv

# ── ML training artefacts (not needed at runtime) ────────────────────────────
ml-module/saved_models/test_predictions.npz
ml-module/saved_models/anomaly_scores.npz

# ── Mobile App - React Native ────────────────────────────────────────────────
MobileApp/node_modules/
MobileApp/.expo/
MobileApp/.expo-shared/

# Android
MobileApp/android/build/
MobileApp/android/app/build/
MobileApp/android/.gradle/
MobileApp/android/local.properties
MobileApp/android/release.keystore
MobileApp/android/app/google-services.json
MobileApp/android/.cxx/

# iOS
MobileApp/ios/build/
MobileApp/ios/Pods/
MobileApp/ios/Podfile.lock
MobileApp/ios/GoogleService-Info.plist

# Metro
MobileApp/.metro-health-check*

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.iml

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
